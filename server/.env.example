# Google Sheets Integration Configuration

# 1. Google Service Account Email
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"

# 2. Google Service Account Private Key (keep the \n formatting)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# 3. Google Sheet ID (from the URL of your Google Sheet)
# E.g., for https://docs.google.com/spreadsheets/d/1BxiMVs0XcX.../edit, ID is 1BxiMVs0XcX...
GOOGLE_SHEET_ID="your-google-sheet-id"
